# TAPD 认证方式一：Access Token（推荐）
TAPD_ACCESS_TOKEN=

# TAPD 认证方式二：API 账号密码
TAPD_API_USER=
TAPD_API_PASSWORD=

# API 地址（默认 https://api.tapd.cn）
TAPD_API_BASE_URL=https://api.tapd.cn

# Web UI 地址（用于生成链接）
TAPD_BASE_URL=https://www.tapd.cn

# 当前用户昵称（用于自动填充 creator/reporter 等字段）
CURRENT_USER_NICK=

# 默认项目 ID（设置后可省略 -w 参数）
TAPD_DEFAULT_WORKSPACE_ID=

# 企业微信机器人 Webhook URL
BOT_URL=
